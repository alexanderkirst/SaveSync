# GBAsync — repo-root environment template. Copy to `.env` and edit. Do not commit `.env`.
#
# Legacy names: each GBASYNC_* key also accepts SAVESYNC_* (same value).
#
# Who reads this: server (uvicorn), Docker entrypoint / sidecar / write_bridge_config,
# and bridge scripts (Dropbox SDK). For local dev, run uvicorn from `server/` so ../ paths work.
# Docker Compose: see server/docker-compose.yml (port 8080, volumes override SAVE_* to /data/...).

# =============================================================================
# API — REQUIRED for a working server
# =============================================================================
SAVE_ROOT=../save_data/saves
HISTORY_ROOT=../save_data/history
INDEX_PATH=../save_data/index.json
API_KEY=password

# =============================================================================
# API — OPTIONAL (sensible defaults)
# =============================================================================
# Versioned backups under HISTORY_ROOT (false = disable history entirely)
ENABLE_VERSION_HISTORY=true
# Cap backups per game (0 = unlimited)
HISTORY_MAX_VERSIONS_PER_GAME=5
# Extra logging when clients POST /debug/client-clock
SAVE_SYNC_LOG_CLIENT_DEBUG=false

# =============================================================================
# Admin web UI — OPTIONAL (omit or leave empty to disable /admin)
# =============================================================================
# Non-empty password enables /admin → /admin/ui; session uses GBASYNC_ADMIN_SECRET or API_KEY
GBASYNC_ADMIN_PASSWORD=
# GBASYNC_ADMIN_SECRET=
# GBASYNC_SLOT_MAP_PATH=

# =============================================================================
# Dropbox auth — REQUIRED only if GBASYNC_DROPBOX_MODE is plain or delta_api
# Use ONE method (see bridge/DROPBOX_SETUP.md). Scopes: files.metadata.read, content read/write
# =============================================================================
# Short-lived token (simplest for testing):
# DROPBOX_ACCESS_TOKEN=

# Long-lived refresh (typical for servers):
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# =============================================================================
# Dropbox ↔ server — REQUIRED when mode is plain or delta_api; ignored when off
# =============================================================================
# Default deployment below matches a typical Delta Harmony + Docker setup (delta_api, server_delta).
GBASYNC_DROPBOX_MODE=delta_api
# Base URL for bridge → API (must match host:port clients use)
GBASYNC_PUBLIC_SERVER_URL=http://127.0.0.1:8080

# --- Sidecar timing (OPTIONAL; defaults in parentheses) ---
# Seconds between scheduled bridge runs (min 10). Long interval + sync-on-upload = mostly event-driven.
GBASYNC_DROPBOX_INTERVAL_SECONDS=86400
# Delay after container start before first sidecar run
GBASYNC_BRIDGE_START_DELAY_SECONDS=8

# --- Upload-triggered sync (OPTIONAL) ---
# After a PUT that stored new bytes, run one Dropbox pass (debounced)
GBASYNC_DROPBOX_SYNC_ON_UPLOAD=true
# Quiet seconds after last such PUT before running (default 10 if unset)
GBASYNC_DROPBOX_SYNC_DEBOUNCE_SECONDS=10
# Bridge subprocess timeout in seconds (default 600 if unset)
# GBASYNC_DROPBOX_SYNC_TIMEOUT_SECONDS=600

# Optional: plain mode only — poll_seconds in generated JSON if different from interval above
# GBASYNC_DROPBOX_POLL_SECONDS=

# --- plain mode only — REQUIRED when GBASYNC_DROPBOX_MODE=plain ---
# DROPBOX_REMOTE_FOLDER=/GBAsync/gba

# --- delta_api mode — REQUIRED when GBASYNC_DROPBOX_MODE=delta_api ---
DROPBOX_REMOTE_DELTA_FOLDER=/Delta Emulator
# Container paths for ROM → game_id (comma-separated; compose often uses /roms)
GBASYNC_ROM_DIRS=/roms
GBASYNC_ROM_EXTENSIONS=.gba
# GBASYNC_ROM_MAP_PATH=

# --- delta_api — OPTIONAL (defaults are fine for most installs) ---
GBASYNC_DELTA_SYNC_MODE=server_delta
# Harmony slot map path (defaults in Docker to /data/delta-slot-map.json if unset)
# GBASYNC_DELTA_SLOT_MAP_PATH=/data/delta-slot-map.json

# --- server_delta merge — OPTIONAL (only matters for two-way; see bridge/delta_folder_server_sync.py) ---
# false = two-way with guardrails: Harmony modifiedDate can win, so admin/3DS/server uploads may NOT be written to the Delta Dropbox folder (you will not see them in Delta until server wins).
# true = whenever server and Dropbox bytes differ, server → Delta (recommended if you inject saves from the admin UI or want 3DS/server to own the cloud copy).
GBASYNC_SERVER_DELTA_ONE_WAY=false
GBASYNC_SERVER_DELTA_MIN_DELTA_WIN_SECONDS=900
GBASYNC_SERVER_DELTA_RECENT_SERVER_PROTECT_SECONDS=3600
