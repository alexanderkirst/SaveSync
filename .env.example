# GBAsync runtime config template (repo root).
# Copy to `.env`. Do not commit `.env`.
#
# Used by:
# - Server (uvicorn / Docker Compose): SAVE_* + API_KEY + GBASYNC_*
# - Dropbox bridge scripts: DROPBOX_* + GBASYNC_*
# - Local uvicorn note: run from `server/` so ../save_data paths resolve.

# -----------------------------------------------------------------------------
# Server core
# -----------------------------------------------------------------------------
SAVE_ROOT=../save_data/saves
HISTORY_ROOT=../save_data/history
INDEX_PATH=../save_data/index.json
API_KEY=change-me
ENABLE_VERSION_HISTORY=true
SAVE_SYNC_LOG_CLIENT_DEBUG=false

# -----------------------------------------------------------------------------
# Admin web UI (optional)
# Set GBASYNC_ADMIN_PASSWORD to enable /admin → /admin/ui (browser login + APIs).
# Session cookie is derived from GBASYNC_ADMIN_PASSWORD + (GBASYNC_ADMIN_SECRET or API_KEY).
# Scripts may use X-API-Key instead of the cookie for /admin/api/*.
# -----------------------------------------------------------------------------
GBASYNC_ADMIN_PASSWORD=
# GBASYNC_ADMIN_SECRET=
# GBASYNC_SLOT_MAP_PATH=

# -----------------------------------------------------------------------------
# Dropbox auth (see bridge/DROPBOX_SETUP.md)
# Use ONE method:
# 1) DROPBOX_ACCESS_TOKEN
# 2) DROPBOX_APP_KEY + DROPBOX_APP_SECRET + DROPBOX_REFRESH_TOKEN
# Required Dropbox scopes: files.metadata.read, files.content.read, files.content.write
# -----------------------------------------------------------------------------
DROPBOX_ACCESS_TOKEN=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Dropbox sync mode (inside server container)
# Modes: off | plain (flat .sav folder) | delta_api (Delta Harmony folder)
# -----------------------------------------------------------------------------
GBASYNC_DROPBOX_MODE=off

# URL sidecar uses to reach this same server/container
GBASYNC_PUBLIC_SERVER_URL=http://127.0.0.1:8080

# Polling / trigger behavior
# Seconds between sync passes when mode is plain or delta_api.
# (bridge sidecar enforces minimum 10 seconds)
# For Delta two-way stability, 120s is a safer starting point than very short intervals.
GBASYNC_DROPBOX_INTERVAL_SECONDS=120
# After a successful PUT that applied new bytes, run one Dropbox pass in background.
GBASYNC_DROPBOX_SYNC_ON_UPLOAD=true
# Debounce upload-triggered sync: run once after this many quiet seconds since last applied PUT.
# GBASYNC_DROPBOX_SYNC_DEBOUNCE_SECONDS=10
# Optional timeout cap for upload-triggered or manual sync subprocess (seconds)
# GBASYNC_DROPBOX_SYNC_TIMEOUT_SECONDS=600
# Wait after container start before first sync (let uvicorn listen)
GBASYNC_BRIDGE_START_DELAY_SECONDS=8

# plain mode only
# DROPBOX_REMOTE_FOLDER=/GBAsync/gba

# delta_api mode only
# DROPBOX_REMOTE_DELTA_FOLDER=/Delta Emulator

# delta_api mode only: ROM lookup inputs
# (compose mounts ${HOME}/Documents/GBA -> /roms by default)
GBASYNC_ROM_DIRS=/roms
GBASYNC_ROM_EXTENSIONS=.gba
# GBASYNC_ROM_MAP_PATH=

# Persistent map: Harmony GameSave slot id -> server game_id (prevents hack/retail remap drift).
# Default in Docker: /data/delta-slot-map.json
# GBASYNC_DELTA_SLOT_MAP_PATH=/data/delta-slot-map.json
GBASYNC_DELTA_SYNC_MODE=server_delta

# delta_api server_delta merge controls
# When hashes differ, who wins? Docker default is one-way (server/3DS -> Delta).
# Set to false only if you want Harmony modifiedDate to beat the server (two-way timestamp merge).
# GBASYNC_SERVER_DELTA_ONE_WAY=true
# GBASYNC_SERVER_DELTA_ONE_WAY=false

# Two-way guardrails (recommended starting values)
# Two-way guardrail: require Delta modifiedDate to be this many seconds newer than server to win.
# Helps prevent immediate flip-back after opening Delta (small metadata bumps).
# Recommended two-way starting value:
# GBASYNC_SERVER_DELTA_MIN_DELTA_WIN_SECONDS=900
# Additional two-way guardrail: after a server update, keep server as winner for this many seconds.
# Useful when Delta opens and bumps modifiedDate immediately after a 3DS upload.
# Recommended two-way starting value:
# GBASYNC_SERVER_DELTA_RECENT_SERVER_PROTECT_SECONDS=3600
